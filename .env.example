# Database — use your Supabase connection string (direct or pooler)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Payload CMS — generate a strong random secret
PAYLOAD_SECRET=your-secret-here-min-32-chars

# Supabase (for newsletter subscriber storage)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LinkedIn webhook URL (optional — set after connecting to your publishing flow)
LINKEDIN_WEBHOOK_URL=https://your-webhook-url.com/endpoint

# Vercel Blob storage (required on Vercel; omit for local dev to use local filesystem)
# Create a Blob store in Vercel Dashboard -> Storage -> Blob, then copy the token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
